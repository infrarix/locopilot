# LocoPilot — Free Tier client configuration
# ─────────────────────────────────────────────────────────────────────────────
# No secrets required. SQLite lives at ~/.locopilot/db.sqlite.
# Pro tier credentials are managed by `locopilot login` and stored in
# ~/.locopilot/config.json — never as env vars on the client.
# ─────────────────────────────────────────────────────────────────────────────

# Where to reach the local Ollama daemon (default: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434

# Port the local API server binds to (default: 8080)
API_PORT=8080

# When set to "true", prompt and completion text is logged for debugging.
# Disabled by default for privacy.
LOCOPILOT_LOG_PROMPTS=false

# Override the LocoPilot Cloud URL (only useful for local Pro-backend dev).
# LOCOPILOT_CLOUD_URL=http://localhost:8081
